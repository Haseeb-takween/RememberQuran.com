# RememberQuran.com — environment template (M4)
# Copy to .env and fill in values. Never commit .env.

# App
AUTH_URL=http://localhost:3000
AUTH_SECRET=

# MongoDB Atlas (user data only — never store Quran text)
# Example: mongodb+srv://USER:PASS@cluster.mongodb.net/rememberquran?retryWrites=true&w=majority
MONGODB_URI=

# Password-reset email (Resend)
RESEND_API_KEY=
EMAIL_FROM=RememberQuran <noreply@rememberquran.com>

# Optional SMTP fallback (if not using Resend)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Quran Foundation Content API (server-only)
# prelive | production
QF_ENV=prelive
QF_CLIENT_ID=
QF_CLIENT_SECRET=

